        {
          "name": "GET Users By Role (Mentor)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.data && json.data.length > 0 && json.data[0]._id) {",
                  "    pm.collectionVariables.set('mentorId', json.data[0]._id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/users?role=mentor",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "users"],
              "query": [
                { "key": "role", "value": "mentor" }
              ]
            }
          },
          "response": []
        }
